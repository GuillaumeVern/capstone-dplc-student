# Determinist version of node:22-alpine to avoid breaking changes in the future
FROM node:alpine3.24

WORKDIR /app

COPY package*.json ./

# npm clean install with no dev dependencies
RUN npm ci --omit=dev

# Copy after npm ci to avoid re-installing dependencies on code changes
COPY . .

RUN chown -R node:node /app

# Adding USER so that the container doesn't run as root
USER node

EXPOSE 3000

CMD ["node", "main.js"]

